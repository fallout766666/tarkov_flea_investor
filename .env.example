# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real keys.

# Primary LLM provider for news extraction and signal fusion.
# Get a key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional fallback / alternate provider.
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override default tarkov.dev GraphQL endpoint.
# TARKOV_DEV_API_URL=https://api.tarkov.dev/graphql

# Required for `flea serve`. Any client calling the API must send this
# value in the X-API-Key header. Generate with `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
FLEA_API_KEY=
